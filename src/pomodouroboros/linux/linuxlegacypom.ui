<interface>
  <!-- interface-name linuxlegacypom.ui -->
  <requires lib="gtk" version="4.2"/>
  <object class="GtkWindow" id="my-window">
    <child>
      <object class="GtkBox">
        <child>
          <object class="GtkLabel">
            <property name="label">somelabeltext</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel"/>
        </child>
        <child>
          <object class="GtkLabel" id="hi"/>
        </child>
      </object>
    </child>
  </object>
</interface>
